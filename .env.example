# ============================================================
# Invoicein — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# --- Supabase (API / server-side) ---
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are used in the Hono API (Cloudflare Worker)
# SERVICE_ROLE_KEY bypasses RLS — never expose this to the client
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# --- Supabase (Web / client-side) ---
# These are safe to expose to the browser — Supabase anon key has no special privileges
# RLS policies + JWT tenant_id scoping protect all data
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=
R2_PUBLIC_URL=https://storage.invoicein.id

# --- Email (Resend) ---
RESEND_API_KEY=re_

# --- WhatsApp (Fonnte) ---
FONNTE_API_KEY=
FONNTE_DEVICE_ID=

# --- Payment (Midtrans) ---
MIDTRANS_SERVER_KEY=SB-Mid-server-
MIDTRANS_CLIENT_KEY=SB-Mid-client-
MIDTRANS_IS_PRODUCTION=false

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-

# --- App URLs ---
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Environment ---
ENVIRONMENT=development
NODE_ENV=development
